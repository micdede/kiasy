# ============================================================
# JARVIS – Konfiguration (.env)
#
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Nur TELEGRAM_TOKEN + ein LLM-Provider sind Pflicht.
# Alles andere ist optional — nicht genutzte Features
# einfach auskommentiert lassen (#).
# ============================================================


# ===================== PFLICHT ==============================

# --- Personalisierung ---
OWNER_NAME=Michael
OWNER_CITY=Berlin
BOT_NAME=JARVIS
# Sprache: de oder en
BOT_LANG=de
TZ=Europe/Berlin

# --- LLM Provider (Pflicht: EINEN auswählen) ---
# Optionen: anthropic | ollama | groq | openai
LLM_PROVIDER=ollama

# Anthropic Claude (empfohlen)
#   → Account erstellen: https://console.anthropic.com
#   → API-Key unter: https://console.anthropic.com/settings/keys
#ANTHROPIC_API_KEY=sk-ant-...
#CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama (kostenlos, lokal oder selbst gehostet)
#   → Installation: https://ollama.com/download
#   → Modell laden: ollama pull llama3.1
#   → Läuft auf http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Groq (kostenlos, schnell, Cloud)
#   → Account erstellen: https://console.groq.com
#   → API-Key unter: https://console.groq.com/keys
#GROQ_API_KEY=gsk_...
#GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI GPT
#   → Account erstellen: https://platform.openai.com
#   → API-Key unter: https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4o

# --- Telegram Bot (Pflicht) ---
#   → Telegram öffnen, @BotFather anschreiben
#   → /newbot → Name + Username wählen → Token kopieren
#   → Deine User-ID: @userinfobot anschreiben
TELEGRAM_TOKEN=DEIN_BOT_TOKEN
# Nur diese User-IDs dürfen den Bot nutzen (kommagetrennt, leer = alle erlaubt)
#TELEGRAM_ALLOWED_USERS=123456789

# --- Allgemein ---
MAX_TOKENS=4096


# ===================== OPTIONAL =============================
# Nicht benötigte Abschnitte einfach auskommentiert lassen.

# --- Sprachnachrichten (Whisper STT + Edge-TTS) ---
#   → Wird automatisch eingerichtet wenn im Install-Script aktiviert
#   → Whisper-Modelle: tiny (schnell), base (Standard), small, medium (genauer)
#   → TTS-Stimmen: https://gist.github.com/BettyJJ/17cbaa1de96235a7f5773b8571a4c138
#WHISPER_MODEL=base
#TTS_VOICE=de-DE-KillianNeural

# --- DALL-E Bildgenerierung ---
#   → Braucht OpenAI API-Key (siehe oben)
#   → Gleicher Key wie für OpenAI LLM, falls schon gesetzt
#OPENAI_API_KEY=sk-proj-...

# --- E-Mail (IMAP/SMTP — Gmail, Outlook, Yahoo, etc.) ---
#   → Funktioniert mit jedem IMAP/SMTP-fähigen Anbieter
#   → Gmail: App-Passwort nötig → https://myaccount.google.com/apppasswords
#   → Outlook: App-Passwort unter https://account.live.com/proofs/manage
#EMAIL_HOST=imap.gmail.com
#EMAIL_USER=dein@gmail.com
#EMAIL_PASSWORD=app-passwort
# Optional: Separate IMAP/SMTP Hosts (default: EMAIL_HOST, smtp. statt imap.)
#EMAIL_IMAP_HOST=imap.gmail.com
#EMAIL_IMAP_PORT=993
#EMAIL_SMTP_HOST=smtp.gmail.com
#EMAIL_SMTP_PORT=587
#EMAIL_FROM=dein@gmail.com
# Berechtigung: read = nur lesen (default), readwrite = auch senden
#EMAIL_MODE=read
# Mails als gelesen markieren erlauben? (default: false)
#EMAIL_MARK_READ=false
# Senden nur an diese Domains/Adressen (fail-secure: leer = alles blockiert)
#EMAIL_ALLOWED_DOMAINS=gmail.com,firma.de
#EMAIL_WHITELIST=chef@firma.de

# --- Kalender (CalDAV — Google, iCloud, Nextcloud, etc.) ---
#   → Google: https://www.googleapis.com/caldav/v2/USER/events
#   → Nextcloud: https://cloud.example.com/remote.php/dav
#   → iCloud: https://caldav.icloud.com
#   → Radicale: http://localhost:5232
#CALDAV_URL=https://caldav.example.com
#CALDAV_USER=dein@example.com
#CALDAV_PASSWORD=app-passwort
# Berechtigung: read = nur lesen (default), readwrite = auch schreiben/löschen
#CALDAV_MODE=read

# --- Home Assistant (Smart Home Steuerung) ---
#   → URL: Deine Home Assistant Adresse (z.B. http://homeassistant.local:8123)
#   → Token erstellen: HA → Profil → Langlebige Zugriffstokens → Token erstellen
#   → Dokumentation: https://www.home-assistant.io/docs/authentication/
#HOMEASSISTANT_URL=http://homeassistant.local:8123
#HOMEASSISTANT_TOKEN=

# --- Kerio Connect (E-Mail, Kalender, Kontakte) ---
#   → Kerio Connect ist ein kommerzieller Mailserver
#   → Wenn du keinen Kerio-Server hast, lass diesen Abschnitt aus
#KERIO_HOST=mail.example.com
#KERIO_USER=jarvis
#KERIO_PASSWORD=
#KERIO_FROM=JARVIS <jarvis@example.com>
# Postfächer überwachen (kommagetrennt, Default: nur INBOX)
#MAIL_WATCH_FOLDERS=INBOX
# Erlaubte Empfänger-Domains für mail_send (fail-secure: leer = alles blockiert)
#MAIL_ALLOWED_DOMAINS=example.com
#MAIL_WHITELIST=

# --- Monitor Dashboard (Web-Oberfläche) ---
#   → HTTPS auf Port 3333 (self-signed Zertifikat)
#   → Zugangsdaten für Basic Auth
MONITOR_USER=admin
MONITOR_PASS=DEIN_PASSWORT
#MONITOR_PORT=3333

# --- Wissensbasis Git-Backup (optional) ---
#   → Synchronisiert notes/ Verzeichnis mit einem Git-Repo
#   → SSH-Key muss bei GitHub/GitLab hinterlegt sein
#GITHUB_NOTES_REPO=git@github.com:user/jarvis-notes.git
