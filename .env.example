# ============================================================
# JARVIS – Konfiguration (.env)
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
# ============================================================

# --- LLM Provider ---
# Optionen: anthropic | ollama | groq | openai
LLM_PROVIDER=ollama

# --- Anthropic (wenn LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Ollama (wenn LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://192.168.178.20:11434/v1
OLLAMA_MODEL=minimax-m2.5:cloud

# --- Groq (wenn LLM_PROVIDER=groq) ---
#GROQ_API_KEY=gsk_...
#GROQ_MODEL=llama-3.1-70b-versatile

# --- Telegram ---
TELEGRAM_TOKEN=DEIN_BOT_TOKEN
# Telegram User-IDs (kommagetrennt). Leer = alle erlaubt.
#TELEGRAM_ALLOWED_USERS=

# --- OpenAI (für DALL-E Bildgenerierung) ---
OPENAI_API_KEY=sk-proj-...

# --- Allgemein ---
MAX_TOKENS=4096

# Whisper Modell für Sprachnachrichten (tiny, base, small, medium)
WHISPER_MODEL=base

# --- TTS (Edge-TTS CLI) ---
TTS_VOICE=de-DE-KillianNeural

# --- WhatsApp (nur für index.js, nicht für telegram.js) ---
#ALLOWED_NUMBERS=

# --- Kerio Connect ---
KERIO_HOST=wrsk-mail.de
KERIO_USER=jarvis
KERIO_PASSWORD=DEIN_PASSWORT
KERIO_FROM=JARVIS <jarvis@wrsk.de>
# Freigegebene Postfächer überwachen (kommagetrennt, Default: nur INBOX)
#MAIL_WATCH_FOLDERS=INBOX,~michael@example.com/INBOX
# Erlaubte Empfänger-Domains für mail_send (kommagetrennt, fail-secure: leer = alles blockiert)
MAIL_ALLOWED_DOMAINS=wrsk.de
# Whitelist für externe E-Mail-Adressen (kommagetrennt)
MAIL_WHITELIST=

# --- Home Assistant ---
HOMEASSISTANT_URL=http://192.168.178.8:8123
HOMEASSISTANT_TOKEN=DEIN_HA_TOKEN

# --- Monitor Auth ---
MONITOR_USER=admin
MONITOR_PASS=DEIN_PASSWORT

# --- Wissensbasis Git Sync ---
#GITHUB_NOTES_REPO=git@github.com:user/jarvis-notes.git
